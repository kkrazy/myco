{
  "name": "myco-monorepo",
  "version": "0.1.0",
  "description": "myco — combined CLI + chat backed by a rules-enforcing model proxy. Root package doubles as the install-from-github entrypoint (bin.myco → cli/index.js); see cli/ for the standalone @myco/cli publish shape.",
  "private": true,
  "workspaces": [
    "cli"
  ],
  "bin": {
    "myco": "./cli/index.js"
  },
  "files": [
    "cli/index.js",
    "cli/src/",
    "cli/share/",
    "cli/README.md",
    "cli/package.json"
  ],
  "dependencies": {
    "highlight.js": "^11.11.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "playwright": "^1.50.0",
    "esbuild": "^0.24.0",
    "codemirror": "^6.0.1",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.34.1",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/language": "^6.10.3",
    "@codemirror/search": "^6.5.6",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-css": "^6.3.0",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/theme-one-dark": "^6.1.2"
  },
  "scripts": {
    "build:editor": "esbuild tools/codemirror-entry.mjs --bundle --format=iife --global-name=MycoCM --minify --outfile=web/public/vendor/codemirror.bundle.js"
  }
}
